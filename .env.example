# ---- Enquiry email (Resend) ----
# Required for enquiries to reach the studio inbox.
# If unset, enquiries are accepted and logged to the server, but not emailed.

# From https://resend.com/api-keys
RESEND_API_KEY=

# Where enquiries land. The studio's Namecheap Private Email inbox.
ENQUIRY_TO_EMAIL=info@copaandglas.com

# The From address for outgoing notification emails.
# Must be on the domain verified in Resend (copaandglas.com).
# This mailbox does NOT need to exist on Namecheap.
# Format: "Display Name <address@domain.com>"
ENQUIRY_FROM_EMAIL=Copa + Glas <enquiries@copaandglas.com>
